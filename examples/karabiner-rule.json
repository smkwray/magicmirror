{
  "description": "Hyper + ' toggles Magic Trackpad orientation",
  "manipulators": [
    {
      "from": {
        "key_code": "quote",
        "modifiers": {
          "mandatory": [
            "left_command",
            "left_control",
            "left_option",
            "left_shift"
          ]
        }
      },
      "to": [
        {
          "set_notification_message": {
            "id": "magic_trackpad_upside_down",
            "text": ""
          }
        },
        {
          "set_notification_message": {
            "id": "trackpad_orientation",
            "text": ""
          }
        },
        {
          "set_notification_message": {
            "id": "trackpad-orientation",
            "text": ""
          }
        },
        {
          "shell_command": "/bin/zsh -lc '$HOME/.hammerspoon/trackpad-orientation/toggle.sh'"
        }
      ],
      "type": "basic"
    }
  ]
}
